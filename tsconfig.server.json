{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "esnext",
    "types": ["node"],
    "skipLibCheck": true,

    /* Module resolution */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Issue #68 (#36 final step): strict mode enabled.
       All 7 preceding issues (#61-#67) replaced 184 `any` with concrete
       types across 21 backend files. The codebase now compiles cleanly
       under strict mode. */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Allow JS files alongside TS during migration */
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "server/**/*.ts",
    "server/**/*.js",
    "shared/**/*.ts"
  ],
  "exclude": [
    "server/**/*.test.js",
    "server/**/*.test.ts"
  ]
}
