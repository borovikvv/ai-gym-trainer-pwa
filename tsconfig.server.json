{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "esnext",
    "types": ["node"],
    "skipLibCheck": true,

    /* Module resolution */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Lax mode — gradual migration. Strict flags will be tightened as
       more modules are converted. */
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,

    /* Allow JS files alongside TS during migration */
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "server/**/*.ts",
    "server/**/*.js",
    "shared/**/*.ts"
  ],
  "exclude": [
    "server/**/*.test.js",
    "server/**/*.test.ts"
  ]
}
