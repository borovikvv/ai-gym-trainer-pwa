# Local API backed by local PostgreSQL
VITE_API_BASE_URL=http://144.31.245.29:8910

# Server-only. Do not expose DATABASE_URL to browser code.
DATABASE_URL=postgres://ai_gym_trainer:***@127.0.0.1:5432/ai_gym_trainer
API_PORT=8910

# Optional OpenAI-compatible LLM for post-workout coach planning.
# If OPENAI_API_KEY/LLM_API_KEY is missing, the API uses deterministic rules fallback.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# LLM_API_KEY/LLM_BASE_URL/LLM_MODEL are also supported as aliases.

# Optional Supabase cloud fallback
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
